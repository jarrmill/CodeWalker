# Supabase — must match the Mastra backend (same project)
# SUPABASE_KEY must be the PUBLIC key (format: sb_publishable_... or the legacy
# anon JWT). Never use the sb_secret_ key in the frontend — it ships to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_

# URL of the Mastra API (local dev default; override for staging/prod)
NUXT_PUBLIC_MASTRA_URL=http://localhost:4111
