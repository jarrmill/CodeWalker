# Model provider
OPENAI_API_KEY=

# Postgres storage (Supabase)
# Use the Supabase "Connection pooling" string (Transaction mode, port 6543)
# for serverless/Vercel. TLS is handled in code via ssl.rejectUnauthorized=false.
# Example: postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Supabase auth (verifies incoming Bearer access tokens — Mastra backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# ── Frontend (frontend/.env) ──────────────────────────────────────────────────
# SUPABASE_URL and SUPABASE_KEY (anon/publishable key) go in frontend/.env.
# NUXT_PUBLIC_MASTRA_URL=http://localhost:4111  (or your Vercel API URL in prod)

# Mastra Observability — https://projects.mastra.ai
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_PROJECT_ID=

# Tool integrations
SHORTCUT_TOKEN=
GITHUB_TOKEN=
