# Model provider
OPENAI_API_KEY=

# Postgres storage (Supabase)
# Use the Supabase "Connection pooling" string (Transaction mode, port 6543)
# for serverless/Vercel. TLS is handled in code via ssl.rejectUnauthorized=false.
# Example: postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Supabase auth (verifies incoming Bearer access tokens — Mastra backend)
# SUPABASE_ANON_KEY must be the PUBLIC key (format: sb_publishable_... or the
# legacy anon JWT). Do NOT use the sb_secret_ key here — it's privileged and
# this value is used like a public/anon key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_

# ── Frontend (frontend/.env) ──────────────────────────────────────────────────
# SUPABASE_URL and SUPABASE_KEY (publishable/anon key) go in frontend/.env.
# See frontend/.env.example.
# NUXT_PUBLIC_MASTRA_URL=http://localhost:4111  (or your Vercel API URL in prod)

# Mastra Observability — https://projects.mastra.ai
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_PROJECT_ID=

# Braintrust Observability — https://www.braintrust.dev
# When BRAINTRUST_API_KEY is set, traces are exported to Braintrust.
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_NAME=codewalker

# Tool integrations
SHORTCUT_TOKEN=
GITHUB_TOKEN=
