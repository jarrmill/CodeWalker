# Model provider
OPENAI_API_KEY=

# Postgres storage (Supabase)
# Use the Supabase "Connection pooling" string (Transaction mode, port 6543)
# for serverless/Vercel. Include ?sslmode=require.
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Supabase auth (verifies incoming Bearer access tokens)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Mastra Observability — https://projects.mastra.ai
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_PROJECT_ID=

# Tool integrations
SHORTCUT_TOKEN=
GITHUB_TOKEN=
